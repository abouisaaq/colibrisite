# Convex
NEXT_PUBLIC_CONVEX_URL=""
# Secret partagé Next ↔ Convex (obligatoire). Générer : openssl rand -base64 32
# Aussi : npx convex env set CONVEX_BRIDGE_SECRET "…"
CONVEX_BRIDGE_SECRET=""

# Database — SQLite local (défaut, sans installation)
DATABASE_URL="file:./prisma/dev.db"

# MySQL local (Docker) — voir LOCAL.md
# DATABASE_URL="mysql://colibris:colibrispassword@localhost:3306/colibris"

# Auth.js
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
AUTH_URL="http://localhost:4000"

# App
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# PayPal (sandbox) — optionnel en local si configuré dans Admin → Paramètres
# Ces variables servent de secours tant que le CMS n'a pas de Client ID + Secret
PAYPAL_MODE="sandbox"
NEXT_PUBLIC_PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""

# Admin seed
SEED_ADMIN_EMAIL="admin@colibris.org"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Administrateur"
