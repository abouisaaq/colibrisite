{
  "name": "colisite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "dev:convex": "convex dev",
    "build": "prisma generate && next build",
    "build:vercel": "convex deploy --cmd 'npm run build'",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma db push",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.mysql.prisma",
    "db:seed:convex": "tsx scripts/seed-convex.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:check": "node scripts/check-db.mjs",
    "setup:local": "prisma db push && npm run db:seed",
    "db:deploy:hostinger": "prisma generate --schema prisma/schema.mysql.prisma && prisma migrate deploy --schema prisma/schema.mysql.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@paypal/react-paypal-js": "^10.1.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@tiptap/extension-image": "^3.27.2",
    "@tiptap/extension-placeholder": "^3.27.2",
    "@tiptap/react": "^3.27.2",
    "@tiptap/starter-kit": "^3.27.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.120",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
